{
  "name": "@leonardaustin/ui",
  "version": "0.1.0",
  "description": "Reusable React component library and application shell for Leonard Austin projects.",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "*.css",
    "**/*.css"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leonardaustin/ui.git",
    "directory": "packages/ui"
  },
  "bugs": {
    "url": "https://github.com/leonardaustin/ui/issues"
  },
  "homepage": "https://github.com/leonardaustin/ui#readme",
  "keywords": [
    "react",
    "components",
    "component-library",
    "design-system",
    "ui"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json && node scripts/build-css.mjs",
    "lint": "eslint ."
  },
  "dependencies": {
    "clsx": "^2.1.1"
  },
  "peerDependencies": {
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "~5.9.3",
    "vite": "^8.0.1"
  }
}
